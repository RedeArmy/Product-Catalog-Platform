# Copy this file as .env and fill in the values.
# This file IS committed to the repository — without real values.
#
#   cp .env.example .env

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=cemaco_db
POSTGRES_USER=cemaco_user
POSTGRES_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_KEY=
JWT_ISSUER=cemaco-api
JWT_AUDIENCE=cemaco-web
JWT_EXPIRES_MINUTES=60

# ─── Uploads ──────────────────────────────────────────────────────────────────
UPLOADS_BASE_URL=http://localhost:5000

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000
